{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "declaration": false,
    "incremental": false,
    "paths": {}
  },
  "include": ["next-env.d.ts", "server/**/*.ts", "core/**/*.ts"],
  "exclude": ["node_modules", "src", "dist"]
}
