{
  "name": "samwise",
  "version": "1.0.0",
  "description": "Persistent autonomous agent orchestration with recipes and workflows",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "samwise": "./dist/cli/cli-interactive-main.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "samwise": "node dist/cli/cli-interactive-main.js",
    "mcp": "node dist/server/mcp-server.js",
    "export-configs": "npx tsx scripts/export-ide-configs.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agent-orchestration",
    "mcp",
    "ai",
    "orchestration",
    "agents",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "-": "^0.0.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "g": "^2.0.1",
    "ora": "^8.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
